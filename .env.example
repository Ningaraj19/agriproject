# ============================================
# AgriAI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ---------- Application ----------
APP_NAME=AgriAI
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql+asyncpg://agriuser:agripass@localhost:5432/agridb

# ---------- Groq LLM (free tier: https://console.groq.com) ----------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---------- Pinecone (cloud vector DB: https://app.pinecone.io) ----------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=agri-knowledge-base

# ---------- HuggingFace Embeddings ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------- Disease Detection ----------
DISEASE_MODEL_PATH=./data/disease_model/model.pth
DISEASE_MODEL_NUM_CLASSES=38

# ---------- Weather (Open-Meteo — free, no key needed) ----------
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# ---------- YouTube ----------
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------- Translation ----------
TRANSLATION_MODEL_KN_EN=Helsinki-NLP/opus-mt-kn-en
TRANSLATION_MODEL_EN_KN=Helsinki-NLP/opus-mt-en-kn

# ---------- Voice ----------
WHISPER_MODEL_SIZE=base
